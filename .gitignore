# Dependencies
node_modules/
client/node_modules/
server/node_modules/
package-lock.json
client/package-lock.json
server/package-lock.json

# Environment variables (client + server — do not commit secrets)
client/.env
client/.env.*
!client/.env.example
server/.env
server/.env.*
!server/.env.example
# Root-level env (optional monorepo / tooling)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
client/dist/
client/build/
server/dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# OS files
Thumbs.db
.DS_Store
*.log

# Uploads and user-generated content
server/uploads/*
!server/uploads/.gitkeep

# Logs folder (Winston logging)
logs/
server/logs/

# Temporary files
*.tmp
*.temp
.cache/

# MongoDB data (if running locally)
data/
*.db

# Coverage reports
coverage/
.nyc_output/

# SSL certificates (dev-only, regenerate on new machines)
*.pem
*.key
*.crt

# Markdown documentation
*.md
